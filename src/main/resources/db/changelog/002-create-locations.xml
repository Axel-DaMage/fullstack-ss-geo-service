<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
    <changeSet id="create-locations-table" author="sanosysalvos">
        <createTable tableName="locations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="mascota_id" type="BIGINT"/>
            <column name="latitud" type="DECIMAL(10,8)" nullable="false"/>
            <column name="longitud" type="DECIMAL(11,8)" nullable="false"/>
            <column name="zona_nombre" type="VARCHAR(100)"/>
            <column name="direccion" type="VARCHAR(255)"/>
            <column name="reportado_en" type="TIMESTAMP" nullable="false"/>
            <column name="zona_id" type="BIGINT">
                <constraints foreignKeyName="fk_location_zone" references="zones(id)" deleteCascade="true"/>
            </column>
            <column name="creado_en" type="TIMESTAMP" nullable="false" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="actualizado_en" type="TIMESTAMP" nullable="false" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </createTable>
        <addIndex tableName="locations" indexName="idx_location_zona">
            <column name="zona_nombre"/>
        </addIndex>
        <addIndex tableName="locations" indexName="idx_location_mascota_id">
            <column name="mascota_id"/>
        </addIndex>
    </changeSet>
</databaseChangeLog>