<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
    <changeSet id="crear-tabla-ubicaciones" author="sanosysalvos">
        <createTable tableName="locations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="id_mascota" type="BIGINT"/>
            <column name="latitud" type="DECIMAL(10,8)"><constraints nullable="false"/></column>
            <column name="longitud" type="DECIMAL(11,8)"><constraints nullable="false"/></column>
            <column name="zona_nombre" type="VARCHAR(100)"/>
            <column name="direccion" type="VARCHAR(255)"/>
            <column name="reportado_en" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="id_zona" type="BIGINT">
                <constraints foreignKeyName="fk_location_zone" references="zones(id)" deleteCascade="true"/>
            </column>
            <column name="creado_en" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
            <column name="actualizado_en" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="locations" indexName="idx_location_zona">
            <column name="zona_nombre"/>
        </createIndex>
        <createIndex tableName="locations" indexName="idx_location_mascota_id">
            <column name="id_mascota"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>